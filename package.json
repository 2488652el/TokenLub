{
  "name": "tokenlub",
  "version": "1.1.0",
  "description": "TokenLub - unified LLM token usage & cost aggregator for Windows and macOS",
  "main": "demo/out/main/index.js",
  "author": "bestzuge@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/2488652el/TokenLub.git"
  },
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:clean": "node -e \"require('fs').rmSync('demo/out',{recursive:true,force:true})\" && electron-vite build",
    "start": "electron-vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"code/src/**/*.{ts,tsx,css,html,json}\" \"drive/src/**/*.{ts,tsx,css,html,json}\" \"demo/tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"code/src/**/*.{ts,tsx,css,html,json}\" \"drive/src/**/*.{ts,tsx,css,html,json}\" \"demo/tests/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "server:start": "tsx drive/src/server/index.ts",
    "prepare": "husky || true",
    "postinstall": "node code/scripts/postinstall-better-sqlite3.cjs && electron-builder install-app-deps",
    "github:prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File github/prepare.ps1",
    "github:audit": "powershell -NoProfile -ExecutionPolicy Bypass -File github/audit.ps1",
    "pack": "node code/scripts/package-release.cjs --platform current --dir",
    "dist": "node code/scripts/package-release.cjs --platform current",
    "dist:win": "node code/scripts/package-release.cjs --platform win --arch x64",
    "dist:mac:x64": "node code/scripts/package-release.cjs --platform mac --arch x64",
    "dist:mac:arm64": "node code/scripts/package-release.cjs --platform mac --arch arm64",
    "dist:mac": "node code/scripts/package-release.cjs --platform mac --arch all"
  },
  "dependencies": {
    "@lobehub/icons": "^5.10.1",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^11.1.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "decimal.js": "^10.4.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.9",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@playwright/test": "^1.46.0",
    "@tailwindcss/forms": "^0.5.9",
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc",
    "eslint-plugin-react-refresh": "^0.4.9",
    "husky": "^9.1.3",
    "lint-staged": "^15.2.7",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.1.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,html,json,md}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.tokenlub.app",
    "productName": "TokenLub",
    "protocols": [
      {
        "name": "TokenLub Sync Binding",
        "schemes": [
          "tokenlub"
        ]
      }
    ],
    "directories": {
      "output": "demo",
      "buildResources": "design/assets"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "2488652el",
        "repo": "TokenLub",
        "releaseType": "release"
      }
    ],
    "files": [
      "demo/out/main/**/*",
      "demo/out/preload/**/*",
      "demo/out/renderer/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "win": {
      "icon": "design/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "design/assets/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TokenLub"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
